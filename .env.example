# Supabase — Project Settings → Database → Connection string
# Use the POOLED connection for DATABASE_URL (app runtime, serverless-safe)
# and the DIRECT connection for DIRECT_URL (migrations only).
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"  # workers only — never expose client-side

# LLM — used by the normalization ladder (spec §4.2) and matcher (§5)
ANTHROPIC_API_KEY=""

# Embeddings — Voyage AI, Anthropic's recommended embedding partner (spec §5)
VOYAGE_API_KEY=""

# CPC feed integrations (spec §8) — add as each is onboarded
TALENT_COM_API_KEY=""
JOOBLE_API_KEY=""

# Canonical site URL — used for sitemap generation, SEO metadata, and
# building absolute links in alert emails.
NEXT_PUBLIC_SITE_URL="https://topezia.com"

# Admin CMS — /admin/waitlist. Pick any long random string. Visit
# /admin/waitlist?token=THIS_VALUE once to authenticate (sets a cookie).
ADMIN_ACCESS_TOKEN=""
