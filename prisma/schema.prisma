// Topezia — Phase 1 database schema
// Mirrors spec §3 (topezia-phase1-spec.md). Update the spec first, then this file.
// Target: Supabase Postgres with the pgvector extension enabled.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL") // Supabase: pooled vs direct connection
  extensions = [vector]
}

// ─────────────────────────────────────────────
// §3.3 Taxonomy — seeded once, extended over time.
// The taxonomy IS the SEO page generator (see §7).
// ─────────────────────────────────────────────

model Vertical {
  id          String   @id @default(uuid())
  slug        String   @unique // e.g. "tech-software"
  name        String
  isDeepTier  Boolean  @default(false) // true for the 4-5 launch verticals
  cardLayout  CardLayout @default(KNOWLEDGE_WORK)
  roles       Role[]
  jobs        Job[]
  createdAt   DateTime @default(now())
}

enum CardLayout {
  KNOWLEDGE_WORK   // Layout A: tech, creative
  STRUCTURED_HOURLY // Layout B: healthcare, trucking
}

model Role {
  id          String   @id @default(uuid())
  slug        String   @unique // seo_slug — drives /jobs/{role-slug}
  name        String
  verticalId  String
  vertical    Vertical @relation(fields: [verticalId], references: [id])
  aliases     RoleAlias[]
  jobs        Job[]
  createdAt   DateTime @default(now())
}

// Raw title strings → canonical role. Rules-first resolution (§4.2).
model RoleAlias {
  id       String @id @default(uuid())
  rawText  String @unique
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])
  resolvedBy ResolutionSource @default(RULE)
}

model Skill {
  id       String   @id @default(uuid())
  slug     String   @unique
  name     String
  // Seed/canonical skills are reviewed=true; skills auto-created from LLM
  // extraction start reviewed=false (spec §3.3 "behind a review flag") so
  // unvetted skills can be excluded from SEO pages / gap-skill counts until
  // a human approves them.
  reviewed Boolean  @default(false)
  aliases  SkillAlias[]
  jobSkills JobSkill[]
  profileSkills ProfileSkill[]
}

model SkillAlias {
  id         String @id @default(uuid())
  rawText    String @unique
  skillId    String
  skill      Skill  @relation(fields: [skillId], references: [id])
  resolvedBy ResolutionSource @default(RULE)
}

enum ResolutionSource {
  RULE
  LLM
  MANUAL
}

// ─────────────────────────────────────────────
// §3.1 Canonical job schema
// ─────────────────────────────────────────────

enum JobSource {
  GREENHOUSE
  LEVER
  ASHBY
  WORKABLE
  SMARTRECRUITERS
  ADZUNA
  JOOBLE
  CPC_FEED
  FREELANCER_COM
  JOBPOSTING_SCHEMA
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  HOURLY
  TEMP
}

// A posting is either a salaried job or a freelance project (click-out to the
// marketplace to bid). Projects reuse the whole Job pipeline — matching,
// insights, dedup — and `kind` is what the feed filters and badges on.
enum JobKind {
  JOB
  PROJECT
}

enum SalaryPeriod {
  YEAR
  HOUR
  DAY
  PER_MILE
  PROJECT
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE_US
  REMOTE_GLOBAL
  // Remote, but scoped somewhere that is neither the US nor everywhere —
  // "Remote - Poland", "Remote (EMEA)". These had nowhere to go before and
  // were stamped REMOTE_US, i.e. shown to US seekers as US-eligible.
  REMOTE_INTL
}

enum Seniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  EXEC
  NOT_APPLICABLE
}

enum JobStatus {
  LIVE
  EXPIRED
  SUSPECTED_DEAD
  DUPLICATE
}

model Job {
  id                 String   @id @default(uuid())
  kind               JobKind  @default(JOB)
  source             JobSource
  sourceUrl          String   // canonical click-out destination
  sourceCompanySlug  String?  // e.g. greenhouse board token
  externalId         String?  // source's own id, for change detection

  titleRaw           String
  titleNormalized    String?
  roleId             String?
  role               Role?    @relation(fields: [roleId], references: [id])
  verticalId         String
  vertical           Vertical @relation(fields: [verticalId], references: [id])

  companyName        String
  companyDomain       String?

  descriptionRaw     String
  descriptionHash    String   // sha256 — dedup + cache key, never re-LLM identical text

  skills             JobSkill[]
  seniority          Seniority @default(NOT_APPLICABLE)
  employmentType     EmploymentType
  salaryMin          Int?
  salaryMax          Int?
  salaryCurrency     String   @default("USD")
  salaryPeriod       SalaryPeriod?

  locationRaw        String?
  locationLat        Float?
  locationLng        Float?
  locationState      String?  // drives SEO state pages; US-only concept
  country            String?  // ISO-3166 alpha-2. null = genuinely unknown, never assume US
  remoteScope        String?  // for remote jobs: "GLOBAL" | region ("EMEA") | ISO-2. null = unstated
  remoteType         RemoteType

  // §3.2 vertical-specific fields — healthcare credentials, CDL class, etc.
  verticalFields     Json?

  // pgvector — title + skills + condensed description.
  // Prisma doesn't natively type `vector`; raw SQL migration adds the column,
  // see prisma/migrations/xxxx_add_embeddings/migration.sql
  // embedding        Unsupported("vector(1536)")?

  postedAt           DateTime?
  firstSeenAt         DateTime @default(now())
  lastVerifiedAt      DateTime @default(now()) // drives the freshness stamp on cards

  status             JobStatus @default(LIVE)
  duplicateOfId      String?
  duplicateOf        Job?     @relation("JobDuplicates", fields: [duplicateOfId], references: [id])
  duplicates         Job[]    @relation("JobDuplicates")

  cpcFeedId          String?  // revenue attribution

  clicks             JobClick[]
  matchScores        MatchScore[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // One row per posting, keyed on the source's OWN stable id. The old dedup
  // keyed on a hash of the normalized description, which made "have we seen
  // this?" depend on our extraction code — changing normalization made every
  // job look new and duplicated the feed. Identity can't drift that way.
  @@unique([source, sourceCompanySlug, externalId])
  @@index([status, country])
  @@index([status, verticalId])
  @@index([descriptionHash])
  @@index([locationState])
  @@index([roleId])
}

model JobSkill {
  jobId      String
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill  @relation(fields: [skillId], references: [id])
  isRequired Boolean @default(true) // required vs nice-to-have — feeds honest gap scoring

  @@id([jobId, skillId])
}

// Ingestion source registry — includes founding-employer careers-page URLs (§4.1, §8)
model Source {
  id             String   @id @default(uuid())
  type           JobSource
  companySlug    String?
  companyName    String?  // display name; ATS APIs often don't return it (§4)
  careersPageUrl String?
  isPriority     Boolean  @default(false) // founding-employer flag
  crawlCadenceHrs Int     @default(24)
  lastCrawledAt  DateTime?
  createdAt      DateTime @default(now())

  waitlistSignup WaitlistSignup?

  @@unique([type, companySlug])
}

// ─────────────────────────────────────────────
// Founding-employer waitlist (spec §8) — feeds the admin CMS view
// and doubles as an ingestion source once careers pages are indexed.
// ─────────────────────────────────────────────

enum HiringVolume {
  ONE_TO_FIVE
  SIX_TO_TWENTY
  TWENTY_PLUS
}

enum WaitlistStatus {
  PENDING    // submitted, not yet indexed
  INDEXED    // careers page pulled into Source table
  ACTIVATED  // founding-employer status confirmed at launch
}

model WaitlistSignup {
  id             String   @id @default(uuid())
  companyName    String
  contactName    String
  email          String
  phone          String?
  careersPageUrl String
  hiringVolume   HiringVolume?
  verticalSlug   String?  // matches Vertical.slug, "other" allowed as free text fallback
  status         WaitlistStatus @default(PENDING)

  // set once this submission is enforced against the "first 100" cap (§8)
  isFoundingMember Boolean @default(false)
  foundingRank     Int?    // sequential rank at signup time, null if cap already hit

  // link to the ingestion source once indexed — keeps the CMS and the
  // pipeline pointing at the same record instead of duplicating data
  sourceId       String?  @unique
  source         Source?  @relation(fields: [sourceId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([verticalSlug])
}

// ─────────────────────────────────────────────
// §3.4 User profile schema
// ─────────────────────────────────────────────

model Profile {
  id               String   @id @default(uuid())
  userId           String   @unique // Supabase auth user id

  resumeFileUrl    String?  // stays null: résumés are parsed in memory, not stored
  resumeText       String?
  // Profile photo. Best-effort extracted from the uploaded CV (DOCX/PDF) as a
  // small thumbnail data URI — NOT the résumé file itself, which we still never
  // store. Null when the CV had no usable photo. User-editable later.
  photoUrl         String?
  // SEO-friendly slug for the public profile at /p/{publicSlug}
  // (e.g. "raheel-ali-k3m9x2"). Stable once set.
  publicSlug       String?  @unique

  fullName         String?
  headlineRoleId   String?
  seniority        Seniority?
  yearsExperience  Float?
  currentLocation  String?  // where they are today, parsed from the résumé —
                            // distinct from `locations` (where they'd WORK)
  industries       String[] // e.g. ["healthcare", "b2b saas"] — trajectory signal
  workHistory      Json?    // structured, LLM-parsed
  education        Json?
  certifications   String[]

  skills           ProfileSkill[]

  // preferences (§3.4)
  employmentTypes  EmploymentType[]
  remoteTypes      RemoteType[]
  locations        String[] // places they'd actually work
  salaryFloor      Int?     // walk-away minimum — the hard filter (§5)
  salaryTarget     Int?     // what they're actually aiming for; scoring signal only,
                            // never a filter (nobody should lose a match for ambition)
  salaryPeriod     SalaryPeriod?
  // Visa reality. Captured and fed to the reranker so why-lines can flag likely
  // sponsorship problems — NOT a hard filter, because we don't extract
  // sponsorship terms from postings, and silently hiding jobs on a guess would
  // be worse than saying nothing.
  workAuthorization WorkAuthorization @default(NOT_SPECIFIED)
  country          String?  // ISO-2, derived from currentLocation; scopes the feed
  verticalsOptIn   String[] // vertical slugs
  tier             MemberTier @default(FREE) // paywall stub — see MemberTier

  // alternate entry path (trucking questionnaire, §3.4) — same shape, resumeFileUrl null
  entryPath        EntryPath @default(RESUME)

  // Bumped on every profile save; MatchScore rows carry the version they were
  // computed under, so a profile edit transparently invalidates the cache (§5).
  matchVersion     String?

  // Prisma doesn't natively type `vector`; added via raw migration
  // embedding      Unsupported("vector(1024)")?

  clicks           JobClick[]
  saves            JobSave[]
  dismissals       JobDismissal[]
  matchScores      MatchScore[]

  // Insight alerts (opt-in from /coach): weekly snapshot + diff of the user's
  // market; an email goes out only when something actually moved.
  insightAlerts     Boolean @default(false)
  insightUnsubToken String  @unique @default(uuid()) // one-click unsubscribe, no login needed
  insightSnapshots  InsightSnapshot[]

  portfolios        Portfolio[]
  portfolioSaves    PortfolioSave[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Cached stage-2 rerank output (spec §5: "cached per profile-version × job").
// One row per (profile, job); re-rank overwrites it and stamps the current
// matchVersion. A cache hit = row exists with matchVersion == profile.matchVersion.
model MatchScore {
  id            String   @id @default(uuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchVersion  String
  score         Int
  matchedSkills String[]
  gapSkills     String[]
  whyLine       String
  createdAt     DateTime @default(now())

  @@unique([profileId, jobId])
  @@index([profileId, matchVersion])
}

enum EntryPath {
  RESUME
  QUESTIONNAIRE
}

// CORE = what the person's roles were hired to do (their professional
// identity); SECONDARY = real adjacent capabilities ("I also build websites").
// Matching, embeddings and stats lead with CORE.
enum SkillTier {
  CORE
  SECONDARY
}

model ProfileSkill {
  profileId  String
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill   @relation(fields: [skillId], references: [id])
  // confidence ≠ proficiency, and conflating them is a bug waiting to happen:
  // confidence = "did the résumé actually say this?" (drives the dashed
  // "confirm?" chip); proficiency = "how good are they?" (feeds match scoring).
  confidence Float   @default(1.0) // 0–1
  proficiency SkillProficiency? // inferred from years/seniority/depth of use
  source     SkillSource @default(RESUME)
  tier       SkillTier @default(CORE)

  @@id([profileId, skillId])
}

enum SkillSource {
  RESUME
  CONFIRMED
  USER_ADDED
}

enum SkillProficiency {
  FAMILIAR // mentioned//exposure
  PROFICIENT // used regularly
  ADVANCED // deep, sustained use
  EXPERT // leads/teaches others in it
}

enum MemberTier {
  FREE
  PREMIUM // reserved: gates the deep roadmap + tracking. Everything is FREE now;
          // this exists so flipping the paywall later is a config change, not a migration.
}

enum WorkAuthorization {
  US_AUTHORIZED // citizen / permanent resident — never needs sponsorship
  AUTHORIZED_NEEDS_FUTURE_SPONSORSHIP // e.g. F-1 OPT: can work now, needs it later
  NEEDS_SPONSORSHIP // needs sponsorship to start
  NOT_SPECIFIED
}

// ─────────────────────────────────────────────
// Signals — ranking fuel (§3.4, §5) and the /go/ redirect log (§6.3)
// ─────────────────────────────────────────────

// A compact weekly capture of a profile's insights, used to diff "what moved"
// between runs — the raw material for insight alerts and the coach page's
// "since last week" card. Payload shape: lib/alerts/insights.ts.
model InsightSnapshot {
  id         String   @id @default(uuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  capturedAt DateTime @default(now())
  payload    Json

  @@index([profileId, capturedAt])
}

model JobClick {
  id         String   @id @default(uuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id])
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id])
  matchScore Int?     // score shown at time of click
  feedPosition Int?   // position in feed at time of click
  cpcAttributed Boolean @default(false)
  createdAt  DateTime @default(now())

  @@index([jobId])
  @@index([profileId])
}

model JobSave {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  jobId     String
  createdAt DateTime @default(now())

  @@unique([profileId, jobId])
}

model JobDismissal {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  jobId     String
  reason    String?  // optional freeform, feeds nightly soft-filter job (§5)
  createdAt DateTime @default(now())

  @@unique([profileId, jobId])
}

// ─────────────────────────────────────────────
// Email alerts (spec §7 capture, §9 delivery) — a saved search per email.
// Captured from SEO pages ("new Account Executive jobs in California"),
// delivered by scripts/send-alerts.ts via Resend.
// ─────────────────────────────────────────────

enum AlertFrequency {
  DAILY
  WEEKLY
}

// Cached LLM-written intro copy for a programmatic SEO page (spec §7:
// "2-3 sentence intro, LLM-written once per page, cached, regenerated
// monthly"). Cached because thousands of pages sharing one templated
// paragraph reads as boilerplate — the whole point is that each page says
// something true and specific about ITS slice of the index. Generated out of
// band by scripts/generate-page-intros.ts; pages never block on the model.
model SeoPageIntro {
  id          String   @id @default(uuid())
  pageKey     String   @unique // canonical path, e.g. "/jobs/account-executive/ca"
  intro       String
  jobCount    Int // count when written — copy cites it, so staleness is visible
  model       String // which model wrote it, for future re-runs
  generatedAt DateTime @default(now())

  @@index([generatedAt])
}

model JobAlert {
  id             String   @id @default(uuid())
  email          String
  // Deterministic key for the saved search; (email, queryKey) is the dedup key.
  // A string rather than a composite of nullable columns, because in Postgres
  // NULLs aren't equal — a composite unique over them wouldn't dedup at all.
  queryKey       String
  label          String   // human-readable, used in the subject line
  roleId         String?
  verticalId     String?
  locationState  String?
  country        String?  // ISO-2, for /jobs/{role}/{country} alerts
  remoteOnly     Boolean  @default(false)
  frequency      AlertFrequency @default(DAILY)
  lastSentAt     DateTime?
  // Double opt-in: nothing is ever sent to an address that hasn't clicked the
  // confirmation link. Protects deliverability (typos and spam-trap addresses
  // bounce → reputation damage) and is the honest consent bar for bulk email.
  confirmedAt    DateTime?
  confirmToken   String   @unique
  unsubscribedAt DateTime?
  unsubToken     String   @unique
  createdAt      DateTime @default(now())

  @@unique([email, queryKey])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// Portfolio — a member's own published work.
//
// NOT to be confused with Job.kind = PROJECT, which is a freelance brief someone
// is hiring for. These are the opposite direction: work already done, shown off.
// The naming overlap is a real trap, so the model, routes (/portfolio) and UI
// copy all say "portfolio" and never "project".
//
// Public by product decision: a portfolio exists to be seen, shared with a
// client who has no account, and indexed. Only creating and saving need auth.
// ─────────────────────────────────────────────────────────────────────────────

enum PortfolioCategory {
  // Marketing & Creative
  BRANDING_IDENTITY
  GRAPHIC_DESIGN
  ILLUSTRATION
  PHOTOGRAPHY
  VIDEO_MOTION
  UI_UX_DESIGN
  SOCIAL_CONTENT
  COPYWRITING
  // Tech & Software
  WEB_APPLICATION
  MOBILE_APP
  API_BACKEND
  OPEN_SOURCE
  DATA_ML
  DEVOPS_INFRA
  TECHNICAL_WRITING
}

enum PortfolioStatus {
  DRAFT
  PUBLISHED
}

enum PortfolioMediaKind {
  IMAGE
  VIDEO
}

model Portfolio {
  id          String            @id @default(uuid())
  profileId   String
  profile     Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Stable public URL, e.g. "monolab-branding-k3m9x2". Never reused.
  slug        String            @unique
  title       String
  description String?
  category    PortfolioCategory
  status      PortfolioStatus   @default(DRAFT)

  // Cover image for the grid. A storage path, resolved to a CDN URL on read.
  coverPath   String?
  // Cover's intrinsic size, so the masonry grid can reserve the right box
  // BEFORE the image loads — without this a Pinterest layout reflows on every
  // image that arrives.
  coverWidth  Int?
  coverHeight Int?

  // Free-text tags, deliberately not FKs to the Skill taxonomy yet: "Technology
  // Used" (Next.js, Figma) largely isn't in a taxonomy built for job skills, and
  // forcing resolution would drop what people actually type. Both are indexed
  // for chip filtering; wiring skills into the taxonomy for matching is a
  // follow-up, once we can see what people really enter.
  skills       String[]
  technologies String[]

  media        PortfolioMedia[]
  saves        PortfolioSave[]

  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([profileId, status])
  @@index([status, publishedAt])
  @@index([category, status, publishedAt])
}

model PortfolioMedia {
  id          String             @id @default(uuid())
  portfolioId String
  portfolio   Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  kind        PortfolioMediaKind

  // IMAGE: storage object path. VIDEO: the canonical watch URL.
  // Never a user-supplied filename — see the upload route.
  path        String
  // VIDEO only: the extracted id, so embeds are built by us rather than by
  // interpolating a user-supplied URL into an iframe src.
  videoId     String?

  width       Int?
  height      Int?
  caption     String?
  position    Int                @default(0)

  createdAt   DateTime @default(now())

  @@index([portfolioId, position])
}

model PortfolioSave {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([profileId, portfolioId])
  @@index([profileId, createdAt])
}
